{
  "name": "vermilian",
  "productName": "Vermilian",
  "version": "1.0.7",
  "description": "monday.com-style Electron desktop client for self-hosted JetBrains YouTrack",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts,.tsx .",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "[ -d out ] || electron-forge package && playwright test",
    "test:e2e:fresh": "electron-forge package && playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report"
  },
