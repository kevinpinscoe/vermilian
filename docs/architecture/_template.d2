direction: right

# --- Actors / External systems ---
# actor: Actor {shape: person}
# external: External Service {shape: cloud}

# --- Application boundary ---
# app: Application Name {
#   layer1: Layer {shape: rectangle}
#   layer2: Layer {shape: rectangle}
# }

# --- Data stores ---
# db: Primary DB {shape: cylinder}
# cache: Cache {shape: cylinder}

# --- Connections (label describes the protocol or data flow) ---
# actor -> app.layer1: HTTPS
# app.layer1 -> app.layer2: internal
# app.layer2 -> db: SQL
# app.layer2 -> cache: key/value

# =============================================================================
# EXAMPLE — replace with your real diagram
