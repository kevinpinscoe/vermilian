direction: right

user: User {shape: person}

vermilion: vermilion {
  ui: Web UI {shape: rectangle}
  api: REST API {shape: rectangle}
  ai: AI Worker {shape: rectangle}
}

db: Database {shape: cylinder}
claude: Claude API {shape: cloud}

user -> vermilion.ui: HTTPS
vermilion.ui -> vermilion.api: REST / JSON
vermilion.api -> db: queries
vermilion.api -> vermilion.ai: task context
vermilion.ai -> claude: prompts
