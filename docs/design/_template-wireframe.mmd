%% --- Option A: Screen flow (flowchart) ---
flowchart TD

    %% Screens
    INBOX["[ Inbox ]"]
    TASK_LIST["[ Task List ]"]
    TASK_DETAIL["[ Task Detail ]"]
    CREATE_FORM["[ Create Task Form ]"]

    %% Actions
    NEW(["+ New Task"])
    SUBMIT(["Submit"])
    CANCEL(["Cancel"])

    %% Decision
    VALID{"Valid?"}

    %% Flow
    INBOX -->|"navigate"| TASK_LIST
    TASK_LIST --> NEW
    TASK_LIST -->|"click row"| TASK_DETAIL
    NEW --> CREATE_FORM
    CREATE_FORM --> SUBMIT
    CREATE_FORM --> CANCEL
    SUBMIT --> VALID
    VALID -->|"yes"| TASK_LIST
    VALID -->|"no — show errors"| CREATE_FORM
    CANCEL --> TASK_LIST


